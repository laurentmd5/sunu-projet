generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x", "windows"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum ProjectRole {
  OWNER
  MANAGER
  MEMBER
}

enum TeamRole {
  OWNER
  MANAGER
  MEMBER
}

enum ProjectCollaboratorScope {
  INTERNAL
  EXTERNAL
}

enum MeetingStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum MeetingProvider {
  NONE
  JITSI
}

enum ActivityType {
  PROJECT_CREATED
  MEMBER_JOINED
  MEMBER_ROLE_UPDATED
  MEMBER_REMOVED
  TASK_CREATED
  TASK_STATUS_UPDATED

  TEAM_CREATED
  TEAM_MEMBER_JOINED
  TEAM_MEMBER_ROLE_UPDATED
  TEAM_MEMBER_REMOVED
  PROJECT_LINKED_TO_TEAM
}

model User {
  id    String @id @default(uuid()) @db.VarChar(36)
  name  String
  email String @unique

  tasks        Task[]
  createdTasks Task[]        @relation("CreatedTasks")
  projects     Project[]     @relation("UserProjects")
  userProjects ProjectUser[]
  activityLogs ActivityLog[] @relation("ActivityActor")

  createdTeams           Team[]             @relation("CreatedTeams")
  teamMembers            TeamMember[]
  createdMeetings        TeamMeeting[]      @relation("CreatedMeetings")
  addedMeetingRecordings MeetingRecording[] @relation("RecordingAddedBy")
}

model Team {
  id          String   @id @default(uuid()) @db.VarChar(36)
  name        String
  description String?
  inviteCode  String   @unique @db.VarChar(50)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdById String @db.VarChar(36)
  createdBy   User   @relation("CreatedTeams", fields: [createdById], references: [id])

  members    TeamMember[]
  projects   Project[]
  meetings   TeamMeeting[]
  recordings MeetingRecording[]
}

model TeamMember {
  id       String   @id @default(uuid()) @db.VarChar(36)
  teamId   String   @db.VarChar(36)
  userId   String   @db.VarChar(36)
  role     TeamRole @default(MEMBER)
  joinedAt DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([userId])
}

model Project {
  id          String   @id @default(uuid()) @db.VarChar(36)
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tasks       Task[]
  inviteCode  String   @unique @db.VarChar(50)

  createdById String @db.VarChar(36)
  createdBy   User   @relation("UserProjects", fields: [createdById], references: [id])

  teamId String? @db.VarChar(36)
  team   Team?   @relation(fields: [teamId], references: [id], onDelete: SetNull)

  meetings TeamMeeting[]

  users        ProjectUser[]
  activityLogs ActivityLog[]
}

model Task {
  id                  String    @id @default(uuid()) @db.VarChar(36)
  name                String
  description         String
  status              String    @default("To Do")
  dueDate             DateTime?
  projectId           String    @db.VarChar(36)
  project             Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user                User?     @relation(fields: [userId], references: [id])
  userId              String?   @db.VarChar(36)
  createdById         String    @db.VarChar(36)
  createdBy           User      @relation("CreatedTasks", fields: [createdById], references: [id])
  solutionDescription String?
}

model ProjectUser {
  id        String                   @id @default(uuid()) @db.VarChar(36)
  userId    String                   @db.VarChar(36)
  projectId String                   @db.VarChar(36)
  role      ProjectRole              @default(MEMBER)
  scope     ProjectCollaboratorScope @default(INTERNAL)

  user    User    @relation(fields: [userId], references: [id])
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
}

model ActivityLog {
  id          String       @id @default(uuid()) @db.VarChar(36)
  projectId   String       @db.VarChar(36)
  actorUserId String       @db.VarChar(36)
  type        ActivityType
  message     String
  createdAt   DateTime     @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  actor   User    @relation("ActivityActor", fields: [actorUserId], references: [id])

  @@index([projectId, createdAt])
}

model TeamMeeting {
  id              String          @id @default(uuid()) @db.VarChar(36)
  title           String
  description     String?
  notes           String?
  scheduledAt     DateTime
  durationMinutes Int?
  status          MeetingStatus   @default(SCHEDULED)
  provider        MeetingProvider @default(NONE)
  externalUrl     String?

  teamId      String  @db.VarChar(36)
  projectId   String? @db.VarChar(36)
  createdById String  @db.VarChar(36)

  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  createdBy User     @relation("CreatedMeetings", fields: [createdById], references: [id])

  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  meetingRecordings MeetingRecording[]

  @@index([teamId, scheduledAt])
  @@index([projectId, scheduledAt])
}

model MeetingRecording {
  id          String   @id @default(uuid()) @db.VarChar(36)
  title       String
  url         String
  description String?
  createdAt   DateTime @default(now())

  meetingId String @db.VarChar(36)
  addedById String @db.VarChar(36)

  meeting TeamMeeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  addedBy User        @relation("RecordingAddedBy", fields: [addedById], references: [id])
  team    Team?       @relation(fields: [teamId], references: [id])
  teamId  String?     @db.VarChar(36)

  @@index([meetingId, createdAt])
}
