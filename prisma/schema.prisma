generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x", "windows"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum ProjectRole {
  OWNER
  MANAGER
  VIEWER
  MEMBER
}

enum TeamRole {
  OWNER
  MEMBER
}

enum ProjectCollaboratorScope {
  INTERNAL
  EXTERNAL
}

enum MeetingStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum MeetingProvider {
  NONE
  JITSI
}

enum ActivityType {
  PROJECT_CREATED
  MEMBER_JOINED
  MEMBER_ROLE_UPDATED
  MEMBER_REMOVED
  TASK_CREATED
  TASK_STATUS_UPDATED

  TEAM_CREATED
  TEAM_MEMBER_JOINED
  TEAM_MEMBER_ROLE_UPDATED
  TEAM_MEMBER_REMOVED
  PROJECT_LINKED_TO_TEAM

  VIEWER_INVITED
  VIEWER_PERMISSIONS_UPDATED
  MANAGER_ASSIGNED
  SUBTEAM_CREATED
  TASK_PRIORITY_CHANGED
  MILESTONE_CREATED
  MILESTONE_COMPLETED
  MILESTONE_DELAYED
  TASK_COMMENT_ADDED
}

model User {
  id    String @id @default(uuid()) @db.VarChar(36)
  name  String
  email String @unique

  tasks         Task[]
  createdTasks  Task[]        @relation("CreatedTasks")
  reviewedTasks Task[]        @relation("TaskReviewedBy")
  projects      Project[]     @relation("UserProjects")
  userProjects  ProjectUser[]
  activityLogs  ActivityLog[] @relation("ActivityActor")

  createdTeams           Team[]             @relation("CreatedTeams")
  ledTeams               Team[]             @relation("TeamLead")
  teamMembers            TeamMember[]
  createdMeetings        TeamMeeting[]      @relation("CreatedMeetings")
  addedMeetingRecordings MeetingRecording[] @relation("RecordingAddedBy")

  taskComments          TaskComment[]        @relation("TaskCommentAuthor")
  meetingParticipations MeetingParticipant[]
  notifications         Notification[]

  credential AuthCredential?
  sessions   Session[]
}

model Team {
  id          String   @id @default(uuid()) @db.VarChar(36)
  name        String
  description String?
  inviteCode  String   @unique @db.VarChar(50)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdById String @db.VarChar(36)
  createdBy   User   @relation("CreatedTeams", fields: [createdById], references: [id])

  projectId  String  @db.VarChar(36)
  parentId   String? @db.VarChar(36)
  leadUserId String? @db.VarChar(36)

  project Project @relation("ProjectTeams", fields: [projectId], references: [id], onDelete: Cascade)

  parent   Team?  @relation("TeamHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children Team[] @relation("TeamHierarchy")

  lead User? @relation("TeamLead", fields: [leadUserId], references: [id], onDelete: SetNull)

  members    TeamMember[]
  meetings   TeamMeeting[]
  recordings MeetingRecording[]
  tasks      Task[]

  @@index([projectId])
  @@index([parentId])
  @@index([leadUserId])
}

model TeamMember {
  id       String   @id @default(uuid()) @db.VarChar(36)
  teamId   String   @db.VarChar(36)
  userId   String   @db.VarChar(36)
  role     TeamRole @default(MEMBER)
  joinedAt DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([userId])
}

model Project {
  id          String   @id @default(uuid()) @db.VarChar(36)
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  inviteCode  String   @unique @db.VarChar(50)

  status    ProjectStatus @default(ACTIVE)
  startDate DateTime?
  endDate   DateTime?

  createdById String @db.VarChar(36)
  createdBy   User   @relation("UserProjects", fields: [createdById], references: [id])

  teams Team[] @relation("ProjectTeams")

  tasks        Task[]
  meetings     TeamMeeting[]
  users        ProjectUser[]
  activityLogs ActivityLog[]
  milestones   Milestone[]

  @@index([status])
}

model Task {
  id                  String     @id @default(uuid()) @db.VarChar(36)
  name                String
  description         String
  status              TaskStatus @default(TODO)
  dueDate             DateTime?
  solutionDescription String?

  priority    TaskPriority @default(MEDIUM)
  tags        Json?
  milestoneId String?      @db.VarChar(36)
  teamId      String?      @db.VarChar(36)

  reviewFeedback String?   @db.Text
  reviewedById   String?   @db.VarChar(36)
  reviewedAt     DateTime?

  projectId   String  @db.VarChar(36)
  userId      String? @db.VarChar(36)
  createdById String  @db.VarChar(36)

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User?   @relation(fields: [userId], references: [id])
  createdBy User    @relation("CreatedTasks", fields: [createdById], references: [id])

  milestone  Milestone?    @relation(fields: [milestoneId], references: [id], onDelete: SetNull)
  team       Team?         @relation(fields: [teamId], references: [id], onDelete: SetNull)
  comments   TaskComment[]
  reviewedBy User?         @relation("TaskReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([userId])
  @@index([milestoneId])
  @@index([teamId])
  @@index([priority])
  @@index([reviewedById])
}

model ProjectUser {
  id          String                   @id @default(uuid()) @db.VarChar(36)
  userId      String                   @db.VarChar(36)
  projectId   String                   @db.VarChar(36)
  role        ProjectRole              @default(MEMBER)
  scope       ProjectCollaboratorScope @default(INTERNAL)
  inviteToken String?                  @unique @db.VarChar(100)

  user    User    @relation(fields: [userId], references: [id])
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  viewerPermissionGrants ViewerPermissionGrant[]

  @@unique([userId, projectId])
  @@index([projectId, role])
}

model ActivityLog {
  id          String       @id @default(uuid()) @db.VarChar(36)
  projectId   String       @db.VarChar(36)
  actorUserId String       @db.VarChar(36)
  type        ActivityType
  message     String
  metadata    Json?
  createdAt   DateTime     @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  actor   User    @relation("ActivityActor", fields: [actorUserId], references: [id])

  @@index([projectId, createdAt])
  @@index([actorUserId])
}

model TeamMeeting {
  id              String          @id @default(uuid()) @db.VarChar(36)
  title           String
  description     String?
  notes           String?
  scheduledAt     DateTime
  durationMinutes Int?
  status          MeetingStatus   @default(SCHEDULED)
  provider        MeetingProvider @default(NONE)
  externalUrl     String?

  teamId      String  @db.VarChar(36)
  projectId   String? @db.VarChar(36)
  createdById String  @db.VarChar(36)

  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  createdBy User     @relation("CreatedMeetings", fields: [createdById], references: [id])

  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  meetingRecordings MeetingRecording[]
  participants      MeetingParticipant[]

  @@index([teamId, scheduledAt])
  @@index([projectId, scheduledAt])
}

model MeetingRecording {
  id          String   @id @default(uuid()) @db.VarChar(36)
  title       String
  url         String
  description String?
  createdAt   DateTime @default(now())

  meetingId String @db.VarChar(36)
  addedById String @db.VarChar(36)

  meeting TeamMeeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  addedBy User        @relation("RecordingAddedBy", fields: [addedById], references: [id])
  team    Team?       @relation(fields: [teamId], references: [id])
  teamId  String?     @db.VarChar(36)

  @@index([meetingId, createdAt])
}

model AuthCredential {
  id           String   @id @default(cuid())
  userId       String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userAgent String?
  ipAddress String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

enum ProjectStatus {
  ACTIVE
  COMPLETED
  ARCHIVED
  ON_HOLD
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum MilestoneStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  DELAYED
}

enum ViewerPermission {
  VIEW_PROJECT_PROGRESS
  VIEW_MEMBER_STATS
  ASSIGN_TASKS
  CREATE_TASK
  VIEW_MEETINGS
  JOIN_MEETINGS
}

model Milestone {
  id          String          @id @default(uuid()) @db.VarChar(36)
  projectId   String          @db.VarChar(36)
  name        String
  description String?
  targetDate  DateTime?
  status      MilestoneStatus @default(PENDING)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   Task[]

  @@index([projectId, status])
  @@index([targetDate])
}

model TaskComment {
  id        String   @id @default(uuid()) @db.VarChar(36)
  taskId    String   @db.VarChar(36)
  authorId  String   @db.VarChar(36)
  body      String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author User @relation("TaskCommentAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([taskId, createdAt])
  @@index([authorId])
}

model ViewerPermissionGrant {
  id            String           @id @default(uuid()) @db.VarChar(36)
  projectUserId String           @db.VarChar(36)
  permission    ViewerPermission
  createdAt     DateTime         @default(now())

  projectUser ProjectUser @relation(fields: [projectUserId], references: [id], onDelete: Cascade)

  @@unique([projectUserId, permission])
  @@index([projectUserId])
}

model MeetingParticipant {
  id        String    @id @default(uuid()) @db.VarChar(36)
  meetingId String    @db.VarChar(36)
  userId    String    @db.VarChar(36)
  joinedAt  DateTime?
  createdAt DateTime  @default(now())

  meeting TeamMeeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([meetingId, userId])
  @@index([userId])
}

model Notification {
  id        String    @id @default(uuid()) @db.VarChar(36)
  userId    String    @db.VarChar(36)
  type      String    @db.VarChar(100)
  title     String
  message   String?
  link      String?   @db.VarChar(255)
  metadata  Json?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, readAt])
}
