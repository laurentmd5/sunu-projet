generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProjectRole {
  OWNER
  MANAGER
  MEMBER
}

enum TeamRole {
  OWNER
  MANAGER
  MEMBER
}

enum ProjectCollaboratorScope {
  INTERNAL
  EXTERNAL
}

enum MeetingStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum MeetingProvider {
  NONE
  JITSI
}

enum ActivityType {
  PROJECT_CREATED
  MEMBER_JOINED
  MEMBER_ROLE_UPDATED
  MEMBER_REMOVED
  TASK_CREATED
  TASK_STATUS_UPDATED

  TEAM_CREATED
  TEAM_MEMBER_JOINED
  TEAM_MEMBER_ROLE_UPDATED
  TEAM_MEMBER_REMOVED
  PROJECT_LINKED_TO_TEAM
}

model User {
  id    String @id @default(uuid())
  name  String
  email String @unique

  tasks        Task[]
  createdTasks Task[]        @relation("CreatedTasks")
  projects     Project[]     @relation("UserProjects")
  userProjects ProjectUser[]
  activityLogs ActivityLog[] @relation("ActivityActor")

  createdTeams    Team[]        @relation("CreatedTeams")
  teamMembers     TeamMember[]
  createdMeetings TeamMeeting[] @relation("CreatedMeetings")
}

model Team {
  id          String   @id @default(uuid())
  name        String
  description String?
  inviteCode  String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdById String
  createdBy   User   @relation("CreatedTeams", fields: [createdById], references: [id])

  members  TeamMember[]
  projects Project[]
  meetings TeamMeeting[]
}

model TeamMember {
  id       String   @id @default(uuid())
  teamId   String
  userId   String
  role     TeamRole @default(MEMBER)
  joinedAt DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([userId])
}

model Project {
  id          String   @id @default(uuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tasks       Task[]
  inviteCode  String   @unique

  createdById String
  createdBy   User   @relation("UserProjects", fields: [createdById], references: [id])

  teamId String?
  team   Team?   @relation(fields: [teamId], references: [id], onDelete: SetNull)

  meetings TeamMeeting[]

  users        ProjectUser[]
  activityLogs ActivityLog[]
}

model Task {
  id                  String    @id @default(uuid())
  name                String
  description         String
  status              String    @default("To Do")
  dueDate             DateTime?
  projectId           String
  project             Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user                User?     @relation(fields: [userId], references: [id])
  userId              String?
  createdById         String
  createdBy           User      @relation("CreatedTasks", fields: [createdById], references: [id])
  solutionDescription String?
}

model ProjectUser {
  id        String                   @id @default(uuid())
  userId    String
  projectId String
  role      ProjectRole              @default(MEMBER)
  scope     ProjectCollaboratorScope @default(INTERNAL)

  user    User    @relation(fields: [userId], references: [id])
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
}

model ActivityLog {
  id          String       @id @default(uuid())
  projectId   String
  actorUserId String
  type        ActivityType
  message     String
  createdAt   DateTime     @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  actor   User    @relation("ActivityActor", fields: [actorUserId], references: [id])

  @@index([projectId, createdAt])
}

model TeamMeeting {
  id              String          @id @default(uuid())
  title           String
  description     String?
  notes           String?
  scheduledAt     DateTime
  durationMinutes Int?
  status          MeetingStatus   @default(SCHEDULED)
  provider        MeetingProvider @default(NONE)
  externalUrl     String?

  teamId      String
  projectId   String?
  createdById String

  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  createdBy User     @relation("CreatedMeetings", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([teamId, scheduledAt])
  @@index([projectId, scheduledAt])
}
